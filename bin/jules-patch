#!/usr/bin/env bash

set -euo pipefail

apply_mode=false

if [[ "${1:-}" == "--apply" ]]; then
    apply_mode=true
    shift
fi

url="${1:-}"
prefix="${2:-}"

if [[ -z "$url" ]]; then
    echo "Usage: $0 [--apply] <session-url> [prefix]"
    exit 1
fi

# Extract session ID
session_id="$(printf '%s\n' "$url" | sed -nE 's|.*\/session\/([0-9]+).*|\1|p')"

if [[ -z "$session_id" ]]; then
    echo "Invalid session URL"
    exit 1
fi

echo "Session ID : $session_id"

if $apply_mode; then
    echo "Applying patch directly..."
    jules remote pull --session "$session_id" --apply
else
    if [[ -z "$prefix" ]]; then
        echo "Prefix is required unless using --apply"
        exit 1
    fi

    # Find first available patch filename
    i=1
    while [[ -e "${prefix}-${i}.patch" ]]; do
        ((i++))
    done

    patch_file="${prefix}-${i}.patch"

    echo "Patch file : $patch_file"

    jules remote pull --session "$session_id" > "$patch_file"
fi
