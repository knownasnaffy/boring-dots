#!/usr/bin/env bash

SUMMARY_SIZE=16

# colors
C_TIME="\033[90m"    # gray
C_SUM="\033[96m"     # cyan
C_BODY="\033[0m"
C_RESET="\033[0m"

# reconstruct real-time base from monotonic
now_real=$(date +%s)
now_mono=$(cut -d' ' -f1 /proc/uptime)
based=$(awk -v r="$now_real" -v m="$now_mono" 'BEGIN {print r - m}')

dunstctl history | jq -r '
  .data[0][]
  | select(.body.data | contains("This site has been updated in the background.") | not)
  | [
      .timestamp.data,
      .summary.data,
      .body.data
    ]
  | @tsv
' | while IFS=$'\t' read -r ts summary body; do

  summary=$(printf "%-${SUMMARY_SIZE}.${SUMMARY_SIZE}s" "$summary")

  # convert monotonic timestamp → real unix time
  sec=$(awk -v ts="$ts" -v b="$based" 'BEGIN {print int(b + ts/1000000)}')

  diff=$((now_real - sec))

  # relative format
  if [ "$diff" -lt 60 ]; then
    time_str="${diff}s ago"
  elif [ "$diff" -lt 3600 ]; then
    time_str="$((diff / 60))m ago"
  elif [ "$diff" -lt 86400 ]; then
    time_str="$((diff / 3600))h ago"
  else
    time_str="$((diff / 86400))d ago"
  fi

  time_str=$(printf "%-8s" "$time_str")

  printf "%b%s%b %b%s%b - %b%s%b\n" \
    "$C_TIME" "$time_str" "$C_RESET" \
    "$C_SUM" "$summary" "$C_RESET" \
    "$C_BODY" "$body" "$C_RESET"

done
