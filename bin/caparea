#!/usr/bin/env python3

import subprocess
import time
import sys
import os
from PIL import Image
from Xlib import X, XK, display
from Xlib.ext import xtest
import threading

# --- config ---

WALLPAPER_CMD = [
    "feh",
    "--bg-fill",
    os.path.expanduser("~/Pictures/wallpaper.png")
]

TMP = f"/tmp/shot_{int(time.time() * 1000)}.png"

OUT_DIR = os.path.expanduser("~/Pictures/Screenshots")
os.makedirs(OUT_DIR, exist_ok=True)

timestamp = time.strftime("%Y%m%d-%H%M%S")
OUT = os.path.join(OUT_DIR, f"Screenshot-{timestamp}.png")

NORMAL_STEP = 25
LARGE_STEP = 100
SMALL_STEP = 5

# --- overlay thread ---

def run_crosshair(stop_flag):
    d = display.Display()
    s = d.screen()
    root = s.root

    win = root.create_window(
        0, 0,
        s.width_in_pixels,
        s.height_in_pixels,
        0,
        s.root_depth,
        X.InputOutput,
        X.CopyFromParent,
        background_pixmap=X.ParentRelative,
        override_redirect=True
    )

    win.map()

    gc_black = win.create_gc(
        foreground=0x000000,
        line_width=3
    )

    gc_white = win.create_gc(
        foreground=s.white_pixel,
        line_width=1
    )

    try:
        while not stop_flag["stop"]:
            pointer = root.query_pointer()
            x = pointer.root_x
            y = pointer.root_y

            win.clear_area()

            # horizontal
            win.poly_line(gc_black, X.CoordModeOrigin, [
                (0, y), (s.width_in_pixels, y)
            ])

            win.poly_line(gc_white, X.CoordModeOrigin, [
                (0, y), (s.width_in_pixels, y)
            ])

            # vertical
            win.poly_line(gc_black, X.CoordModeOrigin, [
                (x, 0), (x, s.height_in_pixels)
            ])

            win.poly_line(gc_white, X.CoordModeOrigin, [
                (x, 0), (x, s.height_in_pixels)
            ])

            d.sync()
            time.sleep(0.01)

    finally:
        try:
            d.ungrab_keyboard(X.CurrentTime)
            d.sync()
        except:
            pass

        win.unmap()
        d.close()

# --- keyboard controller thread ---

def keyboard_controller(stop_flag):
    d = display.Display()
    root = d.screen().root

    root.grab_keyboard(
        True,
        X.GrabModeAsync,
        X.GrabModeAsync,
        X.CurrentTime
    )

    dragging = False

    while not stop_flag["stop"]:
        event = d.next_event()

        if event.type != X.KeyPress:
            continue

        keysym = d.keycode_to_keysym(event.detail, 0)

        state = event.state

        shift = bool(state & X.ShiftMask)
        alt = bool(state & X.Mod1Mask)

        if shift:
            step = LARGE_STEP
        elif alt:
            step = SMALL_STEP
        else:
            step = NORMAL_STEP

        pointer = root.query_pointer()

        x = pointer.root_x
        y = pointer.root_y

        # movement

        if keysym == XK.XK_h:
            x -= step

        elif keysym == XK.XK_l:
            x += step

        elif keysym == XK.XK_k:
            y -= step

        elif keysym == XK.XK_j:
            y += step

        # clamp

        screen = d.screen()

        x = max(0, min(screen.width_in_pixels - 1, x))
        y = max(0, min(screen.height_in_pixels - 1, y))

        root.warp_pointer(x, y)
        d.sync()

        # start drag

        if keysym == XK.XK_v and not dragging:
            xtest.fake_input(d, X.ButtonPress, 1)
            d.sync()
            dragging = True

        # finish drag

        elif keysym == XK.XK_Return and dragging:
            xtest.fake_input(d, X.ButtonRelease, 1)
            d.sync()
            break

        # cancel

        elif keysym in (XK.XK_Escape, XK.XK_q):
            if dragging:
                xtest.fake_input(d, X.ButtonRelease, 1)
                d.sync()

            stop_flag["cancel"] = True
            break

    stop_flag["stop"] = True

# --- main flow ---

# capture screen
subprocess.run(["maim", TMP], check=True)

# freeze frame wallpaper
subprocess.run(["feh", "--bg-fill", TMP], check=True)

stop_flag = {
    "stop": False,
    "cancel": False
}

# overlay thread
overlay_thread = threading.Thread(
    target=run_crosshair,
    args=(stop_flag,)
)

overlay_thread.start()

# keyboard thread
keyboard_thread = threading.Thread(
    target=keyboard_controller,
    args=(stop_flag,)
)

keyboard_thread.start()

time.sleep(0.2)

# run slop
result = subprocess.run(
    ["slop", "-k", "-f", "%x,%y %w,%h"],
    capture_output=True,
    text=True
)

geom = result.stdout.strip()

# cleanup threads
stop_flag["stop"] = True

overlay_thread.join()
keyboard_thread.join()

# restore wallpaper
subprocess.run(WALLPAPER_CMD)

# cleanup cancel
if stop_flag["cancel"] or not geom:
    print("Selection cancelled")

    if os.path.exists(TMP):
        os.remove(TMP)

    sys.exit(1)

# parse geometry
try:
    pos, size = geom.split()

    x, y = map(int, pos.split(","))
    w, h = map(int, size.split(","))

except Exception:
    print("Failed to parse slop geometry")

    os.remove(TMP)
    sys.exit(1)

if w <= 0 or h <= 0:
    print("Invalid selection")

    os.remove(TMP)
    sys.exit(1)

# crop original screenshot
with Image.open(TMP) as img:
    cropped = img.crop((x, y, x + w, y + h))
    cropped.save(OUT)

# cleanup
os.remove(TMP)

print("Saved:", OUT)
