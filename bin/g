#!/usr/bin/env bash

GTD_DIR="$HOME/.local/share/gtd"
INBOX="$GTD_DIR/inbox.md"
NEXT="$GTD_DIR/next.md"
SOMEDAY="$GTD_DIR/someday.md"
PROJECTS="$GTD_DIR/projects.md"
DONE="$GTD_DIR/done.md"

mkdir -p "$GTD_DIR"
for f in "$INBOX" "$NEXT" "$SOMEDAY" "$PROJECTS" "$DONE"; do
  [[ -f "$f" ]] || touch "$f"
done

# Read undone tasks from a file
read_tasks() { grep -E '^- ' "$1" | sed 's/^- //' ; }

# Add an undone task
add_task() { echo "- $1" >> "$2" ; }

# Remove a task (undone) from a file
remove_task() { local tmp; tmp=$(grep -vF "- $1" "$2"); echo "$tmp" > "$2" ; }


show_overview() {
  clear
  gum style --bold --foreground 212 "─ Next Actions ─"
  echo
  local tasks; tasks=$(read_tasks "$NEXT")
  if [[ -z "$tasks" ]]; then
    gum style --faint "  (none)"
  else
    while IFS= read -r t; do gum style "  • $t"; done <<< "$tasks"
  fi
  local inbox_count; inbox_count=$(read_tasks "$INBOX" | wc -l | tr -d ' ')
  echo
  [[ "$inbox_count" -gt 0 ]] && gum style --faint "─ Inbox: $inbox_count ─"
  echo
}

do_add() {
  local task
  task=$(gum input --placeholder "Task description") || return
  [[ -z "$task" ]] && return
  local list
  list=$(gum choose "inbox" "next" "someday" "projects" --header "Add to which list?") || return
  case "$list" in
    inbox)    add_task "$task" "$INBOX" ;;
    next)     add_task "$task" "$NEXT" ;;
    someday)  add_task "$task" "$SOMEDAY" ;;
    projects) add_task "$task" "$PROJECTS" ;;
    *) return
  esac
  gum log --level info "Added to $list: $task"
}

do_browse() {
  local list
  list=$(gum choose "inbox" "next" "someday" "projects" "done" --header "Browse which list?") || return
  local file
  case "$list" in
    inbox)    file="$INBOX" ;;
    next)     file="$NEXT" ;;
    someday)  file="$SOMEDAY" ;;
    projects) file="$PROJECTS" ;;
    done)     file="$DONE" ;;
  esac

  local tasks
  if [[ "$list" == "done" ]]; then
    tasks=$(grep -E '^- \[x\] ' "$file" | sed 's/^- \[x\] //')
  else
    tasks=$(read_tasks "$file")
  fi
  [[ -z "$tasks" ]] && { gum log --level warn "No tasks in $list."; return; }

  local task
  task=$(echo "$tasks" | gum filter --placeholder "Select a task..." --header "$list") || return

  local action
  action=$(gum choose "mark done" "delete" "move" "cancel" --header "Action for: $task") || return

  case "$action" in
    "delete")
      gum confirm "Delete \"$task\"?" && {
        local tmp
        tmp=$(grep -vF "- $task" "$file" | grep -vF "- $task")
        echo "$tmp" > "$file"
      }
      ;;
    "move")
      local dest
      dest=$(gum choose "inbox" "next" "someday" "projects" --header "Move to?") || return
      local dest_file
      case "$dest" in
        inbox)    dest_file="$INBOX" ;;
        next)     dest_file="$NEXT" ;;
        someday)  dest_file="$SOMEDAY" ;;
        projects) dest_file="$PROJECTS" ;;
      esac
      remove_task "$task" "$file"
      add_task "$task" "$dest_file"
      gum log --level info "Moved to $dest: $task"
      ;;
    "cancel") ;;
  esac
}

# Main loop
while true; do
  show_overview
  gum style --faint "[a] add  [b] browse  [q] quit"
  read -r -n1 key
  echo
  case "$key" in
    a) do_add ;;
    b) do_browse ;;
    q|"") break ;;
  esac
done
