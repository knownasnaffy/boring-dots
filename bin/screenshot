#!/usr/bin/env bash

set -euo pipefail

TYPE=""
EDIT=false
DELAY=0
OUTPUT=""

DEFAULT_OUTPUT="${HOME}/Pictures/Screenshots/Screenshot-$(date +%Y%m%d-%H%M%S).png"

for arg in "$@"; do
  # --- TYPE CHECK ---
  if [[ "$arg" == "--screen" || "$arg" == "--window" ]]; then
    if [[ -n "$TYPE" ]]; then
      echo "Error: Multiple types specified (already have '$TYPE', got '$arg')"
      exit 1
    fi
    TYPE="${arg#--}"
    continue
  fi

  # --- EDIT FLAG ---
  if [[ "$arg" == "--edit" ]]; then
    EDIT=true
    continue
  fi

  # --- TIMER CHECK (e.g., 5s) ---
  if [[ "$arg" =~ ^([0-9]+)s$ ]]; then
    DELAY="$arg"
    continue
  fi

  # --- PATH (fallback) ---
  if [[ -z "$OUTPUT" ]]; then
    OUTPUT="$(realpath -m "$arg")"
    continue
  else
    echo "Error: Multiple output paths specified"
    exit 1
  fi
done

# --- VALIDATION ---
if [[ -z "$TYPE" ]]; then
  echo "Error: You must specify '--screen' or '--window'"
  exit 1
fi

# Default path if none provided
if [[ -z "$OUTPUT" ]]; then
  OUTPUT="$DEFAULT_OUTPUT"
fi

# Ensure directory exists
mkdir -p "$(dirname "$OUTPUT")"

# --- TIMER ---
[[ -n "$DELAY" ]] && sleep "$DELAY"

# --- SCREENSHOT ---
case "$TYPE" in
  screen)
    maim "$OUTPUT"
    ;;
  window)
    read -r X Y W H < <(
      i3-msg -t get_tree | jq -r '
        .. | select(.focused?) | "\(.rect.x) \(.rect.y) \(.rect.width) \(.rect.height)"
      '
    )
    maim -g "${W}x${H}+${X}+${Y}" "$OUTPUT"
    ;;
esac

# --- EDIT PLACEHOLDER ---
if [[ "$EDIT" == true ]]; then
  echo "Edit flag detected (not implemented yet)"
fi

echo "Saved: $OUTPUT"
