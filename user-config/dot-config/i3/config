# Please see https://i3wm.org/docs/userguide.html for a complete reference!

set $mod Mod4
set $terminal kitty

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:JetBrainsMono Nerd Font 10
default_border normal
hide_edge_borders both

# Start XDG autostart .desktop files using dex. See also
# https://wiki.archlinux.org/index.php/XDG_Autostart
exec --no-startup-id dex-autostart --autostart --environment i3

# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork -c 333333

exec --no-startup-id nm-applet

exec --no-startup-id sh -c ". ~/.fehbg"

exec --no-startup-id gpaste-client start

exec --no-startup-id qutebrowser
exec --no-startup-id $terminal

set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

bindsym XF86MonBrightnessUp exec --no-startup-id sh -c "brightnessctl set +10% && killall -USR1 i3status"
bindsym XF86MonBrightnessDown exec --no-startup-id sh -c "brightnessctl set 10%- && killall -USR1 i3status"

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# start a terminal
bindsym $mod+Return exec $terminal
bindsym $mod+grave exec xfce4-terminal --drop-down

# kill focused window
bindsym $mod+q kill

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# enter fullscreen mode for the focused container
bindsym $mod+Shift+f fullscreen toggle

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# focus the child container
bindsym $mod+c focus child

# read 1 character and mark the current window with this character
bindsym $mod+m exec i3-input -F 'mark %s' -l 1 -P 'Mark: '

# read 1 character and go to the window with the character
bindsym $mod+g exec i3-input -F '[con_mark="%s"] focus' -l 1 -P 'Goto: '

# Define names for default workspaces for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

workspace_auto_back_and_forth yes
force_display_urgency_hint 1500 ms

assign [class="qutebrowser"] 2
assign [class="Beeper"] 3

assign [class="spotube"] 4
assign [class="Spotube"] 4

assign [class="jetbrains-studio"] 9

for_window [title="NetManTUI"] floating enable


# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart

bindsym $mod+p exec --no-startup-id ~/.local/bin/rofi-gpaste

mode "app" {
        bindsym b exec --no-startup-id ~/.local/opt/Beeper/Beeper.AppImage; mode "default"
        bindsym a exec --no-startup-id ~/.local/opt/android-studio/bin/studio; mode "default"
        bindsym s exec --no-startup-id spotube; mode "default"
        bindsym v exec --no-startup-id vivaldi-stable; mode "default"
        bindsym d exec --no-startup-id rofi -show drun; mode "default"

        bindsym q mode "default"
        bindsym Escape mode "default"
}

bindsym $mod+d mode "app"

mode "open" {
        bindsym p exec --no-startup-id ~/.local/bin/rofi-pass; mode "default"
        bindsym t exec --no-startup-id rofi -show timer -modi timer:$HOME/.local/bin/rofi-timer; mode "default"
        bindsym c exec --no-startup-id rofi -show calc -modi calc -no-show-match -no-sort > /dev/null; mode "default"
        bindsym w exec --no-startup-id kitty -T NetManTUI nmtui; mode "default"

        bindsym q mode "default"
        bindsym Escape mode "default"
}

bindsym $mod+o mode "open"

mode "folder" {
        bindsym p exec --no-startup-id ~/.local/bin/open_folder "$HOME/Pictures"; mode "default"
        bindsym s exec --no-startup-id ~/.local/bin/open_folder "$HOME/Pictures/Screenshots"; mode "default"
        bindsym d exec --no-startup-id ~/.local/bin/open_folder "$HOME/Downloads"; mode "default"
        bindsym b exec --no-startup-id ~/.local/bin/open_folder "$HOME/Downloads/Beeper"; mode "default"
        bindsym o exec --no-startup-id ~/.local/bin/open_folder "$HOME/Documents"; mode "default"
        bindsym v exec --no-startup-id ~/.local/bin/open_folder "$HOME/Videos"; mode "default"

        bindsym q mode "default"
        bindsym Escape mode "default"
}

bindsym $mod+f mode "folder"

mode "window" {
        bindsym h split horizontal; mode "default"
        bindsym v split vertical; mode "default"
        bindsym e layout toggle splith splitv
        bindsym t layout tabbed; mode "default"

        bindsym q mode "default"
        bindsym Escape mode "default"
}

bindsym $mod+w mode "window"

mode "bye" {
        bindsym s exec systemctl poweroff; mode "default"
        bindsym r exec systemctl reboot; mode "default"
        bindsym e exec i3-msg exit; mode "default"
        bindsym l exec --no-startup-id i3lock -c 333333; mode "default"

        bindsym q mode "default"
        bindsym Escape mode "default"
}

bindsym $mod+b mode "bye"

mode "screenshot" {
        bindsym s exec --no-startup-id ~/.local/bin/screenshot --screen; mode "default"
        bindsym w exec --no-startup-id ~/.local/bin/screenshot --window; mode "default"
        bindsym a exec --no-startup-id ~/.local/bin/caparea; mode "default"

        bindsym q mode "default"
        bindsym Escape mode "default"
}

bindsym $mod+s mode "screenshot"

mode "resize" {
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt

        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        bindsym q mode "default"
        bindsym Escape mode "default"
}

bindsym $mod+r mode "resize"

bar {
  font pango:JetBrainsMono Nerd Font 12
  separator_symbol "|"
  tray_padding 4
  colors {
    background #000000
    statusline #FFFFFF
    separator  #666666

    focused_workspace  #83CAFA #51A2DA #FFFFFF
    active_workspace   #3C6EB4 #294172 #FFFFFF
    inactive_workspace #8C8C8C #4C4C4C #888888
    urgent_workspace   #EC69A0 #DB3279 #FFFFFF
    binding_mode       #b691d3 #A07CBC #FFFFFF
  }
  status_command i3status
}
